{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "adaired-2.vercel.app"
        }
      ],
      "destination": "https://adaired.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.adaired.com"
        }
      ],
      "destination": "https://adaired.com/$1",
      "permanent": true
    },

    {
      "source": "/admin-dashboard",
      "destination": "https://dashboard-adaired.vercel.app/auth/login",
      "permanent": true
    },
    {
      "source": "/services/web-designing-and-development",
      "destination": "/services/web-design-and-development-services",
      "permanent": true
    },
    {
      "source": "/admin",
      "destination": "https://ad-admin-five.vercel.app",
      "permanent": true
    }
  ]
}